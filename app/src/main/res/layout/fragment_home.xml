<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primaryGreen"
        android:elevation="4dp"
        app:titleTextColor="@color/white"
        app:titleTextAppearance="@style/ToolbarTitleStyle"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== HEADER HIJAU ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_dashboard_header"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="40dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvGreeting"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Selamat Datang 🌿"
                            android:textColor="#CCFFFFFF"
                            android:textSize="13sp"
                            android:fontFamily="@font/poppins" />

                        <TextView
                            android:id="@+id/tvUsername"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Administrator"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:fontFamily="@font/poppins"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <androidx.cardview.widget.CardView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        app:cardCornerRadius="22dp"
                        app:cardElevation="4dp"
                        app:cardBackgroundColor="#FFFFFF">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="A"
                            android:textColor="@color/primaryGreen"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/poppins"
                            android:gravity="center" />
                    </androidx.cardview.widget.CardView>

                </LinearLayout>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#22FFFFFF"
                    android:layout_marginTop="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="14dp">
                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_app_logo"
                            android:scaleType="fitCenter" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SiPedes"
                                android:textColor="#FFFFFF"
                                android:textSize="15sp"
                                android:fontFamily="@font/poppins"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Platform digital untuk kemajuan dan pemberdayaan desa Indonesia"
                                android:textColor="#CCFFFFFF"
                                android:textSize="10sp"
                                android:fontFamily="@font/poppins"
                                android:lineSpacingExtra="2dp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ===== ILLUSTRATION CARD ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="-20dp"
                android:paddingHorizontal="16dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="140dp"
                            android:src="@drawable/ic_village_illustration"
                            android:scaleType="fitCenter" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="🏡 Desa Digital Indonesia"
                            android:textColor="@color/darkText"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppins"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_marginTop="8dp" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Membangun desa yang maju, mandiri, dan berdaya saing melalui teknologi informasi digital"
                            android:textColor="@color/mediumText"
                            android:textSize="11sp"
                            android:fontFamily="@font/poppins"
                            android:gravity="center"
                            android:lineSpacingExtra="3dp"
                            android:layout_marginTop="4dp"
                            android:paddingHorizontal="12dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ===== CHIP FILTER ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="20dp"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Filter Layanan"
                    android:textColor="@color/darkText"
                    android:textSize="15sp"
                    android:fontFamily="@font/poppins"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupFilter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:chipSpacingHorizontal="6dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipSemua"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🗂 Semua"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins"
                        android:checked="true" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPerhitungan"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📐 Perhitungan"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipProgram"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏘 Program"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPotensi"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌄 Potensi"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipOnline"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌐 Online"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins" />

                </com.google.android.material.chip.ChipGroup>
            </LinearLayout>

            <!-- ===== SECTION MENU ===== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Menu Utama"
                android:textColor="@color/darkText"
                android:textSize="17sp"
                android:fontFamily="@font/poppins"
                android:textStyle="bold"
                android:layout_marginStart="20dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvFilterDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pilih layanan yang tersedia"
                android:textColor="@color/mediumText"
                android:textSize="12sp"
                android:fontFamily="@font/poppins"
                android:layout_marginStart="20dp"
                android:layout_marginBottom="12dp" />

            <!-- Row 1 menu -->
            <LinearLayout
                android:id="@+id/rowMenu1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:weightSum="2">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardRumus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="6dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_menu_green"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="20dp">
                        <ImageView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@drawable/ic_rumus"
                            android:scaleType="fitCenter" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rumus Bangun"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:fontFamily="@font/poppins"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_marginTop="10dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Datar &amp; Ruang"
                            android:textColor="#CCFFFFFF"
                            android:textSize="10sp"
                            android:fontFamily="@font/poppins"
                            android:gravity="center"
                            android:layout_marginTop="3dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardProgram"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="6dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_menu_blue"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="20dp">
                        <ImageView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@drawable/ic_program"
                            android:scaleType="fitCenter" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Program Desa"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:fontFamily="@font/poppins"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_marginTop="10dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kegiatan Digital"
                            android:textColor="#CCFFFFFF"
                            android:textSize="10sp"
                            android:fontFamily="@font/poppins"
                            android:gravity="center"
                            android:layout_marginTop="3dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Row 2 menu -->
            <LinearLayout
                android:id="@+id/rowMenu2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:layout_marginTop="12dp"
                android:weightSum="2">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardPotensi"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="6dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_menu_teal"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="20dp">
                        <ImageView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@drawable/ic_potensi"
                            android:scaleType="fitCenter" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Potensi Desa"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:fontFamily="@font/poppins"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_marginTop="10dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Wisata &amp; UMKM"
                            android:textColor="#CCFFFFFF"
                            android:textSize="10sp"
                            android:fontFamily="@font/poppins"
                            android:gravity="center"
                            android:layout_marginTop="3dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardWebsite"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="6dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_menu_blue"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="20dp">
                        <ImageView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@drawable/ic_website"
                            android:scaleType="fitCenter" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Website"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:fontFamily="@font/poppins"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_marginTop="10dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SiPedes Online"
                            android:textColor="#CCFFFFFF"
                            android:textSize="10sp"
                            android:fontFamily="@font/poppins"
                            android:gravity="center"
                            android:layout_marginTop="3dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Direktori -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardDirektori"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="6dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_menu_teal"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="18dp">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_potensi"
                            android:scaleType="fitCenter" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Direktori Desa"
                                android:textColor="#FFFFFF"
                                android:textSize="15sp"
                                android:fontFamily="@font/poppins"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Infrastruktur · UMKM · SDM"
                                android:textColor="#CCFFFFFF"
                                android:textSize="11sp"
                                android:fontFamily="@font/poppins"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Logout -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:layout_marginTop="12dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardLogout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="6dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_menu_red"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:padding="18dp">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_logout"
                            android:scaleType="fitCenter" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Keluar dari Aplikasi"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:fontFamily="@font/poppins"
                            android:textStyle="bold"
                            android:layout_marginStart="12dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ============================================ -->
            <!-- ✅ SECTION BERITA — BARU                     -->
            <!-- ============================================ -->

            <!-- Divider + Header Berita -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/dividerColor"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="12dp">

                <!-- Garis aksen hijau -->
                <View
                    android:layout_width="4dp"
                    android:layout_height="22dp"
                    android:background="@color/primaryGreen"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📡 Berita Terkini"
                    android:textColor="@color/darkText"
                    android:textSize="17sp"
                    android:fontFamily="@font/poppins"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dari Indonesia"
                    android:textColor="@color/primaryGreen"
                    android:textSize="11sp"
                    android:fontFamily="@font/poppins" />

            </LinearLayout>

            <!-- Loading State (Shimmer placeholder sederhana) -->
            <LinearLayout
                android:id="@+id/shimmerNews"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <!-- Shimmer Card 1 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/white">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="160dp"
                            android:background="#E0E0E0" />
                        <View
                            android:layout_width="200dp"
                            android:layout_height="14dp"
                            android:background="#E0E0E0"
                            android:layout_marginTop="12dp" />
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="12dp"
                            android:background="#E8E8E8"
                            android:layout_marginTop="8dp" />
                        <View
                            android:layout_width="280dp"
                            android:layout_height="12dp"
                            android:background="#E8E8E8"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Shimmer Card 2 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/white">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="160dp"
                            android:background="#E0E0E0" />
                        <View
                            android:layout_width="220dp"
                            android:layout_height="14dp"
                            android:background="#E0E0E0"
                            android:layout_marginTop="12dp" />
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="12dp"
                            android:background="#E8E8E8"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Error State -->
            <TextView
                android:id="@+id/tvNewsError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚠️ Gagal memuat berita"
                android:textColor="@color/errorRed"
                android:textSize="13sp"
                android:fontFamily="@font/poppins"
                android:gravity="center"
                android:padding="24dp"
                android:visibility="gone" />

            <!-- Empty State -->
            <TextView
                android:id="@+id/tvNewsEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📭 Belum ada berita tersedia"
                android:textColor="@color/mediumText"
                android:textSize="13sp"
                android:fontFamily="@font/poppins"
                android:gravity="center"
                android:padding="24dp"
                android:visibility="gone" />

            <!-- ✅ RecyclerView Berita -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvBerita"
                android:layout_width="match_parent"
