<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login">

    <!-- Top wave decoration -->
    <View
        android:id="@+id/topDecoration"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@drawable/bg_dashboard_header"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Logo on top section -->
    <androidx.cardview.widget.CardView
        android:id="@+id/logoCard"
        android:layout_width="90dp"
        android:layout_height="90dp"
        app:cardCornerRadius="45dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toTopOf="@id/topDecoration"
        app:layout_constraintBottom_toBottomOf="@id/topDecoration"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="20dp">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_app_logo"
            android:layout_gravity="center"
            android:scaleType="fitCenter"/>

    </androidx.cardview.widget.CardView>

    <!-- App name on top -->
    <TextView
        android:id="@+id/tvTopAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SiPedes"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:fontFamily="@font/poppins"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="30dp"/>

    <TextView
        android:id="@+id/tvTopSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sistem Informasi Pembangunan Desa"
        android:textColor="#CCFFFFFF"
        android:textSize="11sp"
        android:fontFamily="@font/poppins"
        app:layout_constraintTop_toBottomOf="@id/tvTopAppName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="2dp"/>

    <!-- Main login card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/loginCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="#FFFFFF"
        android:layout_marginHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@id/topDecoration"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="-40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selamat Datang 👋"
                android:textColor="@color/darkText"
                android:textSize="22sp"
                android:fontFamily="@font/poppins"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvWelcomeDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Masuk ke akun Anda untuk mengakses layanan informasi pembangunan desa digital"
                android:textColor="@color/mediumText"
                android:textSize="13sp"
                android:fontFamily="@font/poppins"
                android:layout_marginTop="6dp"
                android:lineSpacingExtra="4dp"/>

            <View
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:background="@color/primaryGreen"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp"/>

            <!-- Username field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilUsername"
                style="@style/InputLayoutStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Username"
                app:startIconDrawable="@drawable/ic_person"
                app:startIconTint="@color/primaryGreen">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etUsername"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:fontFamily="@font/poppins"
                    android:textSize="14sp"
                    android:textColor="@color/darkText"
                    android:imeOptions="actionNext"
                    android:singleLine="true"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPassword"
                style="@style/InputLayoutStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Password"
                android:layout_marginTop="16dp"
                app:startIconDrawable="@drawable/ic_lock"
                app:startIconTint="@color/primaryGreen"
                app:passwordToggleEnabled="true"
                app:endIconMode="password_toggle">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:fontFamily="@font/poppins"
                    android:textSize="14sp"
                    android:textColor="@color/darkText"
                    android:imeOptions="actionDone"
                    android:singleLine="true"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Login Button -->
            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Masuk"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:fontFamily="@font/poppins"
                android:textStyle="bold"
                android:background="@drawable/bg_btn_primary"
                android:layout_marginTop="24dp"
                android:letterSpacing="0.04"
                android:stateListAnimator="@null"/>

            <!-- Footer hint -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Gunakan akun yang telah terdaftar untuk masuk"
                android:textColor="@color/lightText"
                android:textSize="11sp"
                android:fontFamily="@font/poppins"
                android:gravity="center"
                android:layout_marginTop="16dp"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Footer -->
    <TextView
        android:id="@+id/tvFooter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="© 2024 SiPedes — Bina Desa Digital"
        android:textColor="@color/lightText"
        android:textSize="11sp"
        android:fontFamily="@font/poppins"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="24dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
