<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primaryGreen"
        android:elevation="4dp"
        app:titleTextColor="@color/white"
        app:titleTextAppearance="@style/ToolbarTitleStyle"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero Banner -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_dashboard_header"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="28dp"
                android:paddingBottom="48dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    app:cardCornerRadius="40dp"
                    app:cardElevation="8dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <ImageView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_app_logo"
                        android:scaleType="fitCenter" />
                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SiPedes"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp"
                    android:fontFamily="@font/poppins"
                    android:textStyle="bold"
                    android:layout_marginTop="14dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sistem Informasi Pembangunan Desa"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins"
                    android:layout_marginTop="4dp"
                    android:gravity="center" />

                <View
                    android:layout_width="50dp"
                    android:layout_height="3dp"
                    android:background="#80FFFFFF"
                    android:layout_marginTop="14dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✦ Bina Desa Digital ✦"
                    android:textColor="#99FFFFFF"
                    android:textSize="11sp"
                    android:fontFamily="@font/poppins"
                    android:layout_marginTop="10dp"
                    android:letterSpacing="0.08" />

            </LinearLayout>

            <!-- Definisi Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="-24dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <View
                            android:layout_width="4dp"
                            android:layout_height="24dp"
                            android:background="@color/primaryGreen"
                            android:layout_marginEnd="10dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tentang Aplikasi"
                            android:textColor="@color/darkText"
                            android:textSize="17sp"
                            android:fontFamily="@font/poppins"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="SiPedes (Sistem Informasi Pembangunan Desa) adalah platform digital terintegrasi yang dirancang khusus untuk mendukung proses digitalisasi desa di Indonesia dalam program Bina Desa Digital."
                        android:textColor="@color/mediumText"
                        android:textSize="13sp"
                        android:fontFamily="@font/poppins"
                        android:lineSpacingExtra="5dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Topik / Judul -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">
                        <View
                            android:layout_width="4dp"
                            android:layout_height="24dp"
                            android:background="@color/softBlueAccent"
                            android:layout_marginEnd="10dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Topik Bina Desa Digital"
                            android:textColor="@color/darkText"
                            android:textSize="17sp"
                            android:fontFamily="@font/poppins"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Topik item -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                        <View android:layout_width="8dp" android:layout_height="8dp" android:background="@color/primaryGreen" android:layout_marginEnd="12dp"/>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Digitalisasi Pelayanan Desa"
                                android:textColor="@color/darkText" android:textSize="13sp"
                                android:fontFamily="@font/poppins" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Layanan administrasi desa secara online dan efisien"
                                android:textColor="@color/mediumText" android:textSize="11sp"
                                android:fontFamily="@font/poppins"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                        <View android:layout_width="8dp" android:layout_height="8dp" android:background="@color/primaryGreen" android:layout_marginEnd="12dp"/>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Infrastruktur Teknologi Desa"
                                android:textColor="@color/darkText" android:textSize="13sp"
                                android:fontFamily="@font/poppins" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Penyediaan jaringan internet dan perangkat TIK"
                                android:textColor="@color/mediumText" android:textSize="11sp"
                                android:fontFamily="@font/poppins"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                        <View android:layout_width="8dp" android:layout_height="8dp" android:background="@color/primaryGreen" android:layout_marginEnd="12dp"/>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Pemberdayaan SDM Desa"
                                android:textColor="@color/darkText" android:textSize="13sp"
                                android:fontFamily="@font/poppins" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Pelatihan literasi digital bagi warga dan perangkat desa"
                                android:textColor="@color/mediumText" android:textSize="11sp"
                                android:fontFamily="@font/poppins"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <View android:layout_width="8dp" android:layout_height="8dp" android:background="@color/primaryGreen" android:layout_marginEnd="12dp"/>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Pengembangan Ekonomi Digital"
                                android:textColor="@color/darkText" android:textSize="13sp"
                                android:fontFamily="@font/poppins" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="UMKM desa masuk ekosistem e-commerce nasional"
                                android:textColor="@color/mediumText" android:textSize="11sp"
                                android:fontFamily="@font/poppins"/>
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Fitur Aplikasi -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="28dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">
                        <View
                            android:layout_width="4dp"
                            android:layout_height="24dp"
                            android:background="@color/accentOrange"
                            android:layout_marginEnd="10dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fitur Unggulan"
                            android:textColor="@color/darkText"
                            android:textSize="17sp"
                            android:fontFamily="@font/poppins"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Grid fitur 2x2 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="10dp" android:weightSum="2">

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical"
                            android:background="@color/softGray" android:padding="12dp"
                            android:layout_marginEnd="6dp" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="📐" android:textSize="24sp" android:gravity="center"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Rumus Bangun" android:textColor="@color/darkText"
                                android:textSize="11sp" android:fontFamily="@font/poppins"
                                android:textStyle="bold" android:gravity="center" android:layout_marginTop="6dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Kalkulator geometri datar &amp; ruang"
                                android:textColor="@color/mediumText" android:textSize="9sp"
                                android:fontFamily="@font/poppins" android:gravity="center" android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical"
                            android:background="@color/softBlue" android:padding="12dp"
                            android:layout_marginStart="6dp" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🏘️" android:textSize="24sp" android:gravity="center"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Program Desa" android:textColor="@color/darkText"
                                android:textSize="11sp" android:fontFamily="@font/poppins"
                                android:textStyle="bold" android:gravity="center" android:layout_marginTop="6dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Info kegiatan digitalisasi desa"
                                android:textColor="@color/mediumText" android:textSize="9sp"
                                android:fontFamily="@font/poppins" android:gravity="center" android:layout_marginTop="2dp"/>
                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:weightSum="2">

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical"
                            android:background="#E8F5E9" android:padding="12dp"
                            android:layout_marginEnd="6dp" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🌄" android:textSize="24sp" android:gravity="center"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Potensi Desa" android:textColor="@color/darkText"
                                android:textSize="11sp" android:fontFamily="@font/poppins"
                                android:textStyle="bold" android:gravity="center" android:layout_marginTop="6dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Wisata, UMKM &amp; budaya lokal"
                                android:textColor="@color/mediumText" android:textSize="9sp"
                                android:fontFamily="@font/poppins" android:gravity="center" android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical"
                            android:background="#FFF8E1" android:padding="12dp"
                            android:layout_marginStart="6dp" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🌐" android:textSize="24sp" android:gravity="center"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Website SiPedes" android:textColor="@color/darkText"
                                android:textSize="11sp" android:fontFamily="@font/poppins"
                                android:textStyle="bold" android:gravity="center" android:layout_marginTop="6dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Portal informasi desa online"
                                android:textColor="@color/mediumText" android:textSize="9sp"
                                android:fontFamily="@font/poppins" android:gravity="center" android:layout_marginTop="2dp"/>
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
