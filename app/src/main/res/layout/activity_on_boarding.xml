<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor">

    <!-- ViewPager2 untuk slide onboarding -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPagerOnBoarding"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Container Bawah: Dots + Tombol -->
    <LinearLayout
        android:id="@+id/bottomContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="32dp"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Dots Indicator -->
        <com.tbuonomo.viewpagerdotsindicator.DotsIndicator
            android:id="@+id/dotsIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            app:dotsColor="@color/primaryGreenLight"
            app:dotsCornerRadius="8dp"
            app:dotsSize="8dp"
            app:dotsSpacing="6dp"
            app:selectedDotColor="@color/primaryGreen"
            app:progressMode="true"
            android:layout_marginBottom="20dp" />

        <!-- Tombol NEXT (halaman 1 & 2) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Selanjutnya →"
            android:textSize="15sp"
            android:fontFamily="@font/poppins"
            android:textStyle="bold"
            android:textColor="@color/white"
            app:backgroundTint="@color/primaryGreen"
            app:cornerRadius="14dp"
            android:layout_marginBottom="10dp" />

        <!-- Tombol AYO MULAI (halaman terakhir) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAyoMulai"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="🚀 Ayo Mulai!"
            android:textSize="15sp"
            android:fontFamily="@font/poppins"
            android:textStyle="bold"
            android:textColor="@color/white"
            app:backgroundTint="@color/primaryGreen"
            app:cornerRadius="14dp"
            android:visibility="gone"
            android:layout_marginBottom="10dp" />

        <!-- Tombol SKIP (halaman 1 & 2) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSkip"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Lewati"
            android:textSize="13sp"
            android:fontFamily="@font/poppins"
            android:textColor="@color/mediumText"
            app:backgroundTint="@android:color/transparent"
            app:strokeColor="@color/dividerColor"
            app:strokeWidth="1dp"
            app:cornerRadius="14dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>