<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardNewsItem"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ① urlToImage — thumbnail berita -->
        <ImageView
            android:id="@+id/ivNewsThumbnail"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:scaleType="centerCrop"
            android:background="@color/softGray" />

        <!-- Area teks -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="12dp">

            <!-- Baris atas: source.name + publishedAt -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <!-- ② source.name — badge hijau -->
                <TextView
                    android:id="@+id/tvNewsSource"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tag_green"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="3dp"
                    android:textColor="@color/primaryGreen"
                    android:textSize="11sp"
                    android:fontFamily="@font/poppins"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:drawablePadding="4dp" />

                <!-- ③ publishedAt — tanggal di kanan -->
                <TextView
                    android:id="@+id/tvNewsDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:textColor="@color/lightText"
                    android:textSize="10sp"
                    android:fontFamily="@font/poppins" />

            </LinearLayout>

            <!-- ④ title — judul berita -->
            <TextView
                android:id="@+id/tvNewsTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/darkText"
                android:textSize="14sp"
                android:fontFamily="@font/poppins"
                android:textStyle="bold"
                android:maxLines="3"
                android:ellipsize="end"
                android:lineSpacingExtra="2dp"
                android:layout_marginBottom="6dp" />

            <!-- ⑤ description — ringkasan -->
            <TextView
                android:id="@+id/tvNewsDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/mediumText"
                android:textSize="12sp"
                android:fontFamily="@font/poppins"
                android:maxLines="2"
                android:ellipsize="end"
                android:lineSpacingExtra="2dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>