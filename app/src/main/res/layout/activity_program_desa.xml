<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primaryGreen"
        app:title="Program Desa"
        app:titleTextColor="@color/white"
        app:titleTextAppearance="@style/ToolbarTitleStyle"
        app:navigationIcon="@drawable/ic_back"
        android:elevation="4dp"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="?attr/actionBarSize">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero banner -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_dashboard_header"
                android:orientation="vertical"
                android:padding="20dp"
                android:paddingBottom="36dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Program Desa Digital"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:fontFamily="@font/poppins"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Transformasi digital untuk desa yang lebih maju"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins"
                    android:layout_marginTop="4dp"/>

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="130dp"
                    android:src="@drawable/ic_program_illustration"
                    android:scaleType="fitCenter"
                    android:layout_marginTop="16dp"/>

            </LinearLayout>

            <!-- Stats cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:layout_marginTop="-20dp"
                android:weightSum="3">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="6dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="12" android:textSize="24sp" android:textStyle="bold"
                            android:fontFamily="@font/poppins" android:textColor="@color/primaryGreen"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Program" android:textSize="10sp" android:textColor="@color/mediumText"
                            android:fontFamily="@font/poppins" android:gravity="center"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="3dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="6dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="86%" android:textSize="24sp" android:textStyle="bold"
                            android:fontFamily="@font/poppins" android:textColor="#1565C0"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Selesai" android:textSize="10sp" android:textColor="@color/mediumText"
                            android:fontFamily="@font/poppins" android:gravity="center"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="6dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="5K+" android:textSize="24sp" android:textStyle="bold"
                            android:fontFamily="@font/poppins" android:textColor="@color/accentOrange"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Warga" android:textSize="10sp" android:textColor="@color/mediumText"
                            android:fontFamily="@font/poppins" android:gravity="center"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Program List -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Kegiatan Digital Desa"
                android:textColor="@color/darkText"
                android:textSize="17sp"
                android:fontFamily="@font/poppins"
                android:textStyle="bold"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="12dp"/>

            <!-- Program Item 1 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    <View
                        android:layout_width="4dp"
                        android:layout_height="match_parent"
                        android:background="@color/primaryGreen"
                        android:layout_marginEnd="14dp"
                        android:minHeight="60dp"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📡 Pembangunan Infrastruktur Jaringan"
                            android:textColor="@color/darkText" android:textSize="14sp"
                            android:fontFamily="@font/poppins" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Pemasangan WiFi publik dan menara sinyal digital di seluruh wilayah desa"
                            android:textColor="@color/mediumText" android:textSize="12sp"
                            android:fontFamily="@font/poppins" android:layout_marginTop="4dp"
                            android:lineSpacingExtra="2dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="✅ Selesai • 2024"
                            android:textColor="@color/primaryGreen" android:textSize="11sp"
                            android:fontFamily="@font/poppins" android:layout_marginTop="6dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Program Item 2 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    <View
                        android:layout_width="4dp"
                        android:layout_height="match_parent"
                        android:background="#1565C0"
                        android:layout_marginEnd="14dp"
                        android:minHeight="60dp"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="💻 Pelatihan Literasi Digital"
                            android:textColor="@color/darkText" android:textSize="14sp"
                            android:fontFamily="@font/poppins" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Program pelatihan penggunaan teknologi digital bagi warga desa semua usia"
                            android:textColor="@color/mediumText" android:textSize="12sp"
                            android:fontFamily="@font/poppins" android:layout_marginTop="4dp"
                            android:lineSpacingExtra="2dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🔄 Sedang Berjalan • 2024–2025"
                            android:textColor="#1565C0" android:textSize="11sp"
                            android:fontFamily="@font/poppins" android:layout_marginTop="6dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Program Item 3 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    <View
                        android:layout_width="4dp"
                        android:layout_height="match_parent"
                        android:background="@color/accentOrange"
                        android:layout_marginEnd="14dp"
                        android:minHeight="60dp"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🏪 Digitalisasi UMKM Desa"
                            android:textColor="@color/darkText" android:textSize="14sp"
                            android:fontFamily="@font/poppins" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Pendampingan usaha mikro desa masuk platform e-commerce dan pembayaran digital"
                            android:textColor="@color/mediumText" android:textSize="12sp"
                            android:fontFamily="@font/poppins" android:layout_marginTop="4dp"
                            android:lineSpacingExtra="2dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📅 Direncanakan • 2025"
                            android:textColor="@color/accentOrange" android:textSize="11sp"
                            android:fontFamily="@font/poppins" android:layout_marginTop="6dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Program Item 4 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="28dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    <View
                        android:layout_width="4dp"
                        android:layout_height="match_parent"
                        android:background="#00695C"
                        android:layout_marginEnd="14dp"
                        android:minHeight="60dp"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📱 Sistem Informasi Pelayanan Desa"
                            android:textColor="@color/darkText" android:textSize="14sp"
                            android:fontFamily="@font/poppins" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Aplikasi SiPedes untuk mempermudah akses layanan administrasi warga secara digital"
                            android:textColor="@color/mediumText" android:textSize="12sp"
                            android:fontFamily="@font/poppins" android:layout_marginTop="4dp"
                            android:lineSpacingExtra="2dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="✅ Aktif • 2024"
                            android:textColor="#00695C" android:textSize="11sp"
                            android:fontFamily="@font/poppins" android:layout_marginTop="6dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
