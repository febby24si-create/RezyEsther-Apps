<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primaryGreen"
        android:elevation="4dp"
        app:titleTextColor="@color/white"
        app:titleTextAppearance="@style/ToolbarTitleStyle"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Profile Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_dashboard_header"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="28dp"
                android:paddingBottom="52dp">

                <!-- Avatar circle -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cvAvatar"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    app:cardCornerRadius="50dp"
                    app:cardElevation="12dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <TextView
                        android:id="@+id/tvAvatarInitial"
                        android:layout_width="match_parent"
        android:layout_height="match_parent"
                        android:text="RY"
                        android:textColor="@color/primaryGreen"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/poppins"
                        android:gravity="center" />

                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nama Pengembang"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:fontFamily="@font/poppins"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp" />

                <TextView
                    android:id="@+id/tvRole"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mobile Developer · SiPedes"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins"
                    android:layout_marginTop="4dp" />

                <!-- Badge -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="#22FFFFFF"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:layout_marginTop="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎓 Mahasiswa Aktif"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins" />
                </LinearLayout>

            </LinearLayout>

            <!-- Info Card utama -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="10dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="-28dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">
                        <View
                            android:layout_width="4dp"
                            android:layout_height="24dp"
                            android:background="@color/primaryGreen"
                            android:layout_marginEnd="10dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Identitas Pengembang"
                            android:textColor="@color/darkText"
                            android:textSize="16sp"
                            android:fontFamily="@font/poppins"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- NIM -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingVertical="10dp"
                        android:layout_marginBottom="2dp">
                        <LinearLayout
                            android:layout_width="36dp" android:layout_height="36dp"
                            android:background="@color/softGray" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🎫" android:textSize="16sp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="NIM" android:textColor="@color/lightText"
                                android:textSize="11sp" android:fontFamily="@font/poppins"/>
                            <TextView android:id="@+id/tvNim"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="12345678"
                                android:textColor="@color/darkText" android:textSize="14sp"
                                android:fontFamily="@font/poppins" android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="@color/dividerColor"/>

                    <!-- Program Studi -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingVertical="10dp" android:layout_marginBottom="2dp">
                        <LinearLayout
                            android:layout_width="36dp" android:layout_height="36dp"
                            android:background="@color/softGray" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="📚" android:textSize="16sp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Program Studi" android:textColor="@color/lightText"
                                android:textSize="11sp" android:fontFamily="@font/poppins"/>
                            <TextView android:id="@+id/tvProdi"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Teknik Informatika"
                                android:textColor="@color/darkText" android:textSize="14sp"
                                android:fontFamily="@font/poppins" android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="@color/dividerColor"/>

                    <!-- Universitas -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingVertical="10dp" android:layout_marginBottom="2dp">
                        <LinearLayout
                            android:layout_width="36dp" android:layout_height="36dp"
                            android:background="@color/softGray" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🏛️" android:textSize="16sp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Universitas" android:textColor="@color/lightText"
                                android:textSize="11sp" android:fontFamily="@font/poppins"/>
                            <TextView android:id="@+id/tvUniversitas"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Universitas Anda"
                                android:textColor="@color/darkText" android:textSize="14sp"
                                android:fontFamily="@font/poppins" android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="@color/dividerColor"/>

                    <!-- Email -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingVertical="10dp">
                        <LinearLayout
                            android:layout_width="36dp" android:layout_height="36dp"
                            android:background="@color/softGray" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="✉️" android:textSize="16sp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Email" android:textColor="@color/lightText"
                                android:textSize="11sp" android:fontFamily="@font/poppins"/>
                            <TextView android:id="@+id/tvEmail"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="email@mahasiswa.ac.id"
                                android:textColor="@color/primaryGreen" android:textSize="13sp"
                                android:fontFamily="@font/poppins" android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Kontribusi Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="28dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">
                        <View
                            android:layout_width="4dp"
                            android:layout_height="24dp"
                            android:background="@color/accentOrange"
                            android:layout_marginEnd="10dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kontribusi dalam Proyek"
                            android:textColor="@color/darkText"
                            android:textSize="16sp"
                            android:fontFamily="@font/poppins"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Mengembangkan aplikasi Android SiPedes sebagai bagian dari program Bina Desa Digital menggunakan teknologi Kotlin, ViewBinding, Material Design, dan WebView untuk menghadirkan layanan informasi pembangunan desa secara mobile."
                        android:textColor="@color/mediumText"
                        android:textSize="13sp"
                        android:fontFamily="@font/poppins"
                        android:lineSpacingExtra="5dp"
                        android:layout_marginBottom="14dp" />

                    <!-- Tech stack badges -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Kotlin" android:background="@color/softBlue"
                            android:textColor="#1565C0" android:textSize="11sp"
                            android:fontFamily="@font/poppins" android:textStyle="bold"
                            android:paddingHorizontal="10dp" android:paddingVertical="4dp"
                            android:layout_marginEnd="6dp" android:layout_marginBottom="6dp"/>

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="ViewBinding" android:background="@color/softGray"
                            android:textColor="@color/darkText" android:textSize="11sp"
                            android:fontFamily="@font/poppins" android:textStyle="bold"
                            android:paddingHorizontal="10dp" android:paddingVertical="4dp"
                            android:layout_marginEnd="6dp" android:layout_marginBottom="6dp"/>

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Material Design" android:background="#E8F5E9"
                            android:textColor="@color/primaryGreen" android:textSize="11sp"
                            android:fontFamily="@font/poppins" android:textStyle="bold"
                            android:paddingHorizontal="10dp" android:paddingVertical="4dp"
                            android:layout_marginEnd="6dp" android:layout_marginBottom="6dp"/>

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="WebView" android:background="#FFF3E0"
                            android:textColor="@color/accentOrange" android:textSize="11sp"
                            android:fontFamily="@font/poppins" android:textStyle="bold"
                            android:paddingHorizontal="10dp" android:paddingVertical="4dp"
                            android:layout_marginBottom="6dp"/>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
