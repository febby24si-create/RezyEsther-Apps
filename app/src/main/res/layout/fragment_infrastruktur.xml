<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header Info -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/primaryGreen">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏗️ Status Infrastruktur"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Desa Maju Jaya — Tahun 2025"
                    android:textColor="@color/lightGreen"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Ringkasan Statistik 2x2 Grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- Jalan Desa -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🛣️"
                        android:textSize="28sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12.5 km"
                        android:textColor="@color/primaryGreen"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/poppins"
                        android:layout_marginTop="6dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Jalan Desa"
                        android:textColor="@color/mediumText"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Fasilitas Kesehatan -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏥"
                        android:textSize="28sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3 Unit"
                        android:textColor="@color/primaryGreen"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/poppins"
                        android:layout_marginTop="6dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Faskes"
                        android:textColor="@color/mediumText"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <!-- Sekolah -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏫"
                        android:textSize="28sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5 Unit"
                        android:textColor="@color/primaryGreen"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/poppins"
                        android:layout_marginTop="6dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sekolah"
                        android:textColor="@color/mediumText"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Irigasi -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💧"
                        android:textSize="28sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="8.2 km"
                        android:textColor="@color/primaryGreen"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/poppins"
                        android:layout_marginTop="6dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Irigasi"
                        android:textColor="@color/mediumText"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Program Sedang Berjalan -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Program Aktif"
            android:textColor="@color/darkText"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/poppins"
            android:layout_marginBottom="8dp" />

        <!-- Item Program 1 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/white">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp">
                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="🏗️"
                    android:textSize="22sp"
                    android:gravity="center" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pavingisasi Jalan RT 04"
                        android:textColor="@color/darkText"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/poppins" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dana Desa 2025 · Progres 65%"
                        android:textColor="@color/mediumText"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins" />
                </LinearLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Aktif"
                    android:textColor="@color/primaryGreen"
                    android:textSize="11sp"
                    android:fontFamily="@font/poppins"
                    android:textStyle="bold"
                    android:background="@drawable/bg_menu_green"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Item Program 2 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/white">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp">
                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="💡"
                    android:textSize="22sp"
                    android:gravity="center" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Instalasi Listrik Solar Panel"
                        android:textColor="@color/darkText"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/poppins" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bantuan Kemendes · Progres 30%"
                        android:textColor="@color/mediumText"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins" />
                </LinearLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Aktif"
                    android:textColor="@color/primaryGreen"
                    android:textSize="11sp"
                    android:fontFamily="@font/poppins"
                    android:textStyle="bold"
                    android:background="@drawable/bg_menu_green"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Item Program 3 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/white">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp">
                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="🚰"
                    android:textSize="22sp"
                    android:gravity="center" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pipanisasi Air Bersih"
                        android:textColor="@color/darkText"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/poppins" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="APBD 2025 · Selesai"
                        android:textColor="@color/mediumText"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins" />
                </LinearLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Selesai"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:fontFamily="@font/poppins"
                    android:textStyle="bold"
                    android:background="@drawable/bg_menu_teal"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>